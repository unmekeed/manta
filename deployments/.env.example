# Пример переменных окружения для `make stack-up` (docker compose).
# Скопируйте в `deployments/.env` и заполните. Файл .env — в .gitignore,
# реальные секреты НЕ коммитятся.

# Telegram-уведомления об авто-обучении (training/notify.py). Пусто —
# уведомления выключены.
TELEGRAM_BOT_TOKEN=
# id чата назначения. Если пусто — определится из getUpdates по последнему
# написавшему боту (один раз отправьте боту /start).
TELEGRAM_CHAT_ID=

# OpenDota API-ключ (opendota.com/api-keys) — снимает суточный лимит
# анонимного тарифа (~2000-3000 запросов/сутки на IP, сгорает за 3-4ч при
# текущих коллекторах). Пусто — коллекторы ходят анонимно.
OPENDOTA_API_KEY=

# Шардирование сбора между несколькими машинами с РАЗНЫМИ IP (у каждого IP
# своя квота OpenDota ~3000/сутки). Каждая машина берёт свой класс вычетов
# match_id по модулю — пересечения нет, слияние баз через dataset-import
# конфликт-фри. COUNT одинаков на всех, ID различается.
#   ПК №1: COLLECTOR_SHARD_COUNT=2  COLLECTOR_SHARD_ID=0   (чётные match_id)
#   ПК №2: COLLECTOR_SHARD_COUNT=2  COLLECTOR_SHARD_ID=1   (нечётные)
# Пусто/1 — одиночная машина, фильтр пропускает всё.
COLLECTOR_SHARD_COUNT=1
COLLECTOR_SHARD_ID=0
