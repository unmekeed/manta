# Пример переменных окружения для `make stack-up` (docker compose).
# Скопируйте в `deployments/.env` и заполните. Файл .env — в .gitignore,
# реальные секреты НЕ коммитятся.

# Telegram-уведомления об авто-обучении (training/notify.py). Пусто —
# уведомления выключены.
TELEGRAM_BOT_TOKEN=
# id чата назначения. Если пусто — определится из getUpdates по последнему
# написавшему боту (один раз отправьте боту /start).
TELEGRAM_CHAT_ID=

# LLM-нарратив отчётов (report-generator, narrative.py). Пусто —
# шаблонный бейзлайн без обращений к API. Ключ: platform.claude.com →
# API Keys (sk-ant-...). Оплата по токенам, ~1 цент за отчёт на opus.
ANTHROPIC_API_KEY=
# Модель нарратива; для экономии можно claude-haiku-4-5 (~5x дешевле).
NARRATIVE_MODEL=claude-opus-4-8
