{
 "title": "Платформа: конвейер и модель",
 "uid": "dota-pipeline",
 "timezone": "browser",
 "refresh": "30s",
 "time": {
  "from": "now-3h",
  "to": "now"
 },
 "panels": [
  {
   "id": 1,
   "title": "Реплеи: скорость разбора (rate/мин)",
   "type": "timeseries",
   "gridPos": {
    "h": 8,
    "w": 12,
    "x": 0,
    "y": 0
   },
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "fieldConfig": {
    "defaults": {
     "unit": "short"
    },
    "overrides": []
   },
   "targets": [
    {
     "expr": "rate(replays_parsed_total[5m]) * 60",
     "legendFormat": "{{job}}",
     "refId": "A"
    }
   ]
  },
  {
   "id": 2,
   "title": "Разбор реплея: p50/p95, сек",
   "type": "timeseries",
   "gridPos": {
    "h": 8,
    "w": 12,
    "x": 12,
    "y": 0
   },
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "fieldConfig": {
    "defaults": {
     "unit": "s"
    },
    "overrides": []
   },
   "targets": [
    {
     "expr": "histogram_quantile(0.95, rate(replay_parse_duration_seconds_bucket[15m]))",
     "legendFormat": "p95",
     "refId": "A"
    }
   ]
  },
  {
   "id": 3,
   "title": "Фичи и отчёты (rate/мин)",
   "type": "timeseries",
   "gridPos": {
    "h": 8,
    "w": 12,
    "x": 0,
    "y": 8
   },
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "fieldConfig": {
    "defaults": {
     "unit": "short"
    },
    "overrides": []
   },
   "targets": [
    {
     "expr": "rate(features_calculated_total[5m]) * 60 or rate(reports_generated_total[5m]) * 60",
     "legendFormat": "{{__name__}}",
     "refId": "A"
    }
   ]
  },
  {
   "id": 4,
   "title": "Инференс: латентность p95, сек",
   "type": "timeseries",
   "gridPos": {
    "h": 8,
    "w": 12,
    "x": 12,
    "y": 8
   },
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "fieldConfig": {
    "defaults": {
     "unit": "s"
    },
    "overrides": []
   },
   "targets": [
    {
     "expr": "histogram_quantile(0.95, rate(ml_predict_latency_seconds_bucket[15m]))",
     "legendFormat": "p95",
     "refId": "A"
    }
   ]
  },
  {
   "id": 5,
   "title": "API: p95 длительность по маршрутам, сек",
   "type": "timeseries",
   "gridPos": {
    "h": 8,
    "w": 12,
    "x": 0,
    "y": 16
   },
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "fieldConfig": {
    "defaults": {
     "unit": "s"
    },
    "overrides": []
   },
   "targets": [
    {
     "expr": "histogram_quantile(0.95, sum by (le, route) (rate(api_request_duration_seconds_bucket[15m])))",
     "legendFormat": "{{route}}",
     "refId": "A"
    }
   ]
  },
  {
   "id": 6,
   "title": "Ошибки: DLQ и сбои (rate/мин)",
   "type": "timeseries",
   "gridPos": {
    "h": 8,
    "w": 12,
    "x": 12,
    "y": 16
   },
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "fieldConfig": {
    "defaults": {
     "unit": "short"
    },
    "overrides": []
   },
   "targets": [
    {
     "expr": "rate(replays_dlq_total[5m]) * 60 or rate(features_failed_total[5m]) * 60 or rate(reports_failed_total[5m]) * 60 or rate(collector_cycles_failed_total[5m]) * 60",
     "legendFormat": "{{__name__}}",
     "refId": "A"
    }
   ]
  }
 ],
 "schemaVersion": 39
}